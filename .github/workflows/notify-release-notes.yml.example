# Copy this file to each source repo (revive-api, revive-admin, revive-dashboard, revive-mobile)
# as .github/workflows/notify-release-notes.yml
#
# Prerequisites:
#   1. Create a personal access token (PAT) with "repo" scope that can access revive-api-docs.
#   2. Add it as a repository secret named DOCS_DISPATCH_TOKEN in each source repo.

name: Trigger release notes generation

on:
  release:
    types: [published]

jobs:
  notify-docs:
    runs-on: ubuntu-latest
    steps:
      - name: Dispatch to revive-api-docs
        uses: peter-evans/repository-dispatch@v3
        with:
          token: ${{ secrets.DOCS_DISPATCH_TOKEN }}
          repository: Revive-Home/revive-api-docs
          event-type: generate-release-notes
          client-payload: '{"release_version": "${{ github.event.release.tag_name }}"}'
